# ---- App ----
ENV=dev
APP_NAME=oi-agent
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=pretty
LOG_SCOPE=normal

# ---- Google Cloud ----
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Gemini / ADK ----
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
ADK_APP_NAME=oi-adk-chatbot

# ---- Firebase ----
FIREBASE_PROJECT_ID=your-project-id
FIRESTORE_DATABASE=(default)

# ---- Pub/Sub ----
PUBSUB_TOPIC_TASKS=oi-tasks
PUBSUB_SUBSCRIPTION_TASKS=oi-tasks-sub

# ---- Cloud Storage ----
GCS_BUCKET_UPLOADS=oi-uploads

# ---- Voice ----
TTS_LANGUAGE_CODE=en-US
TTS_VOICE_NAME=en-US-Neural2-D

# ---- Email (Gmail SMTP) ----
# For Gmail: enable "App Passwords" in Google Account > Security
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ---- Feature Flags ----
ENABLE_LIVE_STREAMING=true
ENABLE_COMPUTER_USE=false
ENABLE_VISION_TOOLS=true
ENABLE_BROWSER_AUTOMATION=false

# ---- Device Enrollment ----
ENROLLMENT_TTL_SECONDS=600
NONCE_TTL_SECONDS=300

# ---- Security ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
REQUEST_TIMEOUT_SECONDS=30
MAX_TOOL_CALLS_PER_REQUEST=10
RUNNER_SHARED_SECRET=replace-me
AUTOMATION_SCHEDULER_MODE=embedded
AUTOMATION_SCHEDULER_CLAIM_TTL_SECONDS=900
AUTH_SESSION_COOKIE_NAME=oi_session
AUTH_SESSION_COOKIE_TTL_SECONDS=432000
AUTH_CSRF_COOKIE_NAME=oi_csrf
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_CSRF_SECRET=

# ---- Managed Remote Browser ----
# Enable this to let the backend create a server_runner session from the UI.
SERVER_RUNNER_ENABLED=false
SERVER_RUNNER_BACKEND=local_process

# Local-process backend (development / trusted backend host)
SERVER_RUNNER_COMMAND=pnpm --dir apps/frontend/desktop runner:headless
SERVER_RUNNER_CWD=
SERVER_RUNNER_API_BASE_URL=
# Set one of these:
SERVER_RUNNER_CHROME_PATH=
SERVER_RUNNER_CDP_URL=
SERVER_RUNNER_BOOTSTRAP_URL=https://example.com
SERVER_RUNNER_START_TIMEOUT_SECONDS=30

# Cloud Run backend (production)
# Requires a worker image that keeps the container alive, listens on PORT,
# starts Chromium, and launches the headless runner with the env below.
SERVER_RUNNER_CLOUD_RUN_SERVICE_PREFIX=oi-remote-session
SERVER_RUNNER_CLOUD_RUN_WORKER_IMAGE=
SERVER_RUNNER_CLOUD_RUN_SERVICE_ACCOUNT=
SERVER_RUNNER_CLOUD_RUN_CPU=1
SERVER_RUNNER_CLOUD_RUN_MEMORY=2Gi
SERVER_RUNNER_CLOUD_RUN_TIMEOUT_SECONDS=3600
SERVER_RUNNER_CLOUD_RUN_MIN_INSTANCES=1
SERVER_RUNNER_CLOUD_RUN_MAX_INSTANCES=1
SERVER_RUNNER_CLOUD_RUN_INGRESS=internal

VITE_BYPASS_WEB_AUTH=true
