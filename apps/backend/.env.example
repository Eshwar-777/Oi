# ---- App ----
ENV=dev
APP_NAME=oi-agent
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=pretty
LOG_SCOPE=normal

# ---- Google Cloud ----
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Gemini / ADK ----
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_LIVE_MODEL_FALLBACKS=gemini-live-2.5-flash-native-audio,gemini-live-2.5-flash-preview-native-audio-09-2025,gemini-2.0-flash-live-001
ADK_APP_NAME=oi-adk-chatbot

# ---- Firebase ----
FIREBASE_PROJECT_ID=your-project-id
FIRESTORE_DATABASE=(default)

# ---- Pub/Sub ----
PUBSUB_TOPIC_TASKS=oi-tasks
PUBSUB_SUBSCRIPTION_TASKS=oi-tasks-sub

# ---- Cloud Storage ----
GCS_BUCKET_UPLOADS=oi-uploads

# ---- Voice ----
TTS_LANGUAGE_CODE=en-US
TTS_VOICE_NAME=en-US-Neural2-D

# ---- Email (Gmail SMTP) ----
# For Gmail: enable "App Passwords" in Google Account > Security
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ---- Feature Flags ----
ENABLE_LIVE_STREAMING=true
ENABLE_COMPUTER_USE=false
ENABLE_VISION_TOOLS=true
ENABLE_BROWSER_AUTOMATION=false

# ---- Device Enrollment ----
ENROLLMENT_TTL_SECONDS=600
NONCE_TTL_SECONDS=300

# ---- Security ----
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081
REQUEST_TIMEOUT_SECONDS=30
MAX_TOOL_CALLS_PER_REQUEST=10
AUTOMATION_SCHEDULER_MODE=embedded
AUTOMATION_SCHEDULER_CLAIM_TTL_SECONDS=900
AUTH_SESSION_COOKIE_NAME=oi_session
AUTH_SESSION_COOKIE_TTL_SECONDS=432000
AUTH_CSRF_COOKIE_NAME=oi_csrf
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_CSRF_SECRET=

VITE_BYPASS_WEB_AUTH=true
