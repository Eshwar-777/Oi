rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Users — each user can read their own profile and device list
    // -----------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-only

      match /devices/{deviceId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // server-only (written by backend on enrollment/revoke)
      }
    }

    // -----------------------------------------------------------------------
    // Devices — server-only writes; authenticated users can read their linked devices
    // -----------------------------------------------------------------------
    match /devices/{deviceId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/devices/$(deviceId)/links/$(request.auth.uid))
                  && get(/databases/$(database)/documents/devices/$(deviceId)/links/$(request.auth.uid)).data.status == "active";
      allow write: if false; // server-only

      match /credentials/{keyVersion} {
        allow read, write: if false; // server-only (keys must never be readable by clients)
      }

      match /links/{uid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // server-only
      }
    }

    // -----------------------------------------------------------------------
    // Enrollments — server-only (backend creates and completes)
    // -----------------------------------------------------------------------
    match /enrollments/{enrollmentId} {
      allow read, write: if false; // server-only
    }

    // -----------------------------------------------------------------------
    // Device nonces — server-only (PoP replay prevention)
    // -----------------------------------------------------------------------
    match /device_nonces/{nonceHash} {
      allow read, write: if false; // server-only
    }

    // -----------------------------------------------------------------------
    // Mesh groups — members can read, server writes
    // -----------------------------------------------------------------------
    match /mesh_groups/{groupId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;
      allow write: if false; // server-only
    }

    // -----------------------------------------------------------------------
    // Task documents — owner or mesh group members can read
    // -----------------------------------------------------------------------
    match /tasks/{taskId} {
      allow read: if request.auth != null
                  && (resource.data.created_by_user_id == request.auth.uid);
      allow write: if false; // server-only
    }
  }
}
