{
  "manifest_version": 3,
  "name": "OI Browser Assistant",
  "version": "0.1.0",
  "description": "OI automates browser tasks on your behalf.",
  "permissions": [
    "activeTab",
    "tabs",
    "tabGroups",
    "scripting",
    "notifications",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "OI"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
