{
  "expo": {
    "name": "OI",
    "slug": "oi",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "oi",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#751636"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oi.app"
    },
    "android": {
      "package": "com.oi.app",
      "adaptiveIcon": {
        "backgroundColor": "#751636"
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#751636"
        }
      ]
    ]
  }
}
