{
  "name": "@oi/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "dev": "pnpm run build:main && electron .",
    "build": "pnpm run build:main && electron-builder",
    "runner:headless": "pnpm run build:main && node dist/runnerCli.js",
    "worker:headless": "pnpm run build:main && node dist/remoteWorker.js",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.13",
    "electron": "30.5.1",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
